---
import '@fontsource-variable/inter';
import '@fontsource/jetbrains-mono';
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import BackgroundEffect from '../components/landing/BackgroundEffect.astro';
import ScrollProgress from '../components/landing/ScrollProgress.astro';
import BackToTop from '../components/landing/BackToTop.astro';
import CommandPalette from '../components/landing/CommandPalette.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Arbitus — The security proxy for AI agents and MCP servers',
  description = 'Open-source security proxy that enforces per-agent policies — auth, rate limiting, payload filtering, and audit — before any tool call reaches your MCP server.',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, 'https://arbitus-gateway.xyz');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta id="color-scheme-meta" name="color-scheme" content="light" />
    <link rel="canonical" href={canonical} />
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL('/arbitus-text-logo.webp', canonical)} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL('/arbitus-text-logo.webp', canonical)} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="512x512" href="/arbitus-logo.png" />
    <link rel="apple-touch-icon" href="/arbitus-logo.png" />
    
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "Organization",
            "@id": "https://arbitus-gateway.xyz/#organization",
            "name": "Arbitus",
            "url": "https://arbitus-gateway.xyz",
            "logo": {
              "@type": "ImageObject",
              "url": "https://arbitus-gateway.xyz/arbitus-logo.png",
              "width": 512,
              "height": 512
            },
            "sameAs": [
              "https://github.com/arbitusgateway/arbitus"
            ]
          },
          {
            "@type": "WebSite",
            "@id": "https://arbitus-gateway.xyz/#website",
            "url": "https://arbitus-gateway.xyz",
            "name": "Arbitus",
            "description": "The security proxy for AI agents and MCP servers",
            "publisher": {
              "@id": "https://arbitus-gateway.xyz/#organization"
            }
          },
          {
            "@type": "SoftwareApplication",
            "name": "Arbitus",
            "description": "Open-source security proxy that enforces per-agent policies — auth, rate limiting, payload filtering, and audit — before any tool call reaches your MCP server.",
            "applicationCategory": "SecurityApplication",
            "operatingSystem": "Linux, macOS, Windows",
            "url": "https://arbitus-gateway.xyz",
            "offers": {
              "@type": "Offer",
              "price": "0",
              "priceCurrency": "USD"
            },
            "publisher": {
              "@id": "https://arbitus-gateway.xyz/#organization"
            }
          },
          {
            "@type": "WebPage",
            "@id": "https://arbitus-gateway.xyz/#webpage",
            "url": "https://arbitus-gateway.xyz",
            "name": "Arbitus — The security proxy for AI agents and MCP servers",
            "isPartOf": {
              "@id": "https://arbitus-gateway.xyz/#website"
            },
            "about": {
              "@id": "https://arbitus-gateway.xyz/#organization"
            }
          },
          {
            "@type": "FAQPage",
            "@id": "https://arbitus-gateway.xyz/#faq",
            "mainEntity": [
              {
                "@type": "Question",
                "name": "What is Arbitus?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Arbitus is an open-source security proxy that sits between AI agents and MCP servers. It enforces per-agent policies including authentication, rate limiting, payload filtering, and audit logging before any tool call reaches your upstream MCP server."
                }
              },
              {
                "@type": "Question",
                "name": "How do I install Arbitus?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Install Arbitus with: cargo install arbitus. You can also use Docker (docker pull ghcr.io/arbitusgateway/arbitus:latest) or download pre-built binaries from the GitHub releases page."
                }
              },
              {
                "@type": "Question",
                "name": "What security features does Arbitus provide?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Arbitus provides per-agent authentication (API key, JWT/OIDC, mTLS), rate limiting, encoding-aware payload filtering, prompt injection detection, schema validation, OPA/Rego policies, human-in-the-loop approval, shadow mode for dry runs, supply-chain verification with SHA-256 and cosign, and complete audit logging."
                }
              },
              {
                "@type": "Question",
                "name": "Is Arbitus free and open source?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Yes, Arbitus is MIT licensed and fully open source. It's written in pure Rust with sub-millisecond overhead and is available for free on GitHub and crates.io."
                }
              }
            ]
          }
        ]
      }
    </script>
    
    <link rel="preconnect" href="https://github.com" />
    <link rel="dns-prefetch" href="https://github.com" />
    
    <script is:inline>
      (function() {
        var stored = typeof localStorage !== 'undefined' && localStorage.getItem('starlight-theme');
        var theme = stored || (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
        document.documentElement.dataset.theme = theme === 'light' ? 'light' : 'dark';
        document.getElementById('color-scheme-meta').setAttribute('content', theme === 'light' ? 'light' : 'dark');
      })();
    </script>
    <script>
      const initScrollAnimations = () => {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
            }
          });
        }, { threshold: 0.1 });

        document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
      };

      document.addEventListener('astro:page-load', initScrollAnimations);
      initScrollAnimations();
    </script>
    <ClientRouter />
    <title>{title}</title>
  </head>
  <body class="font-sans antialiased">
    <BackgroundEffect />
    <ScrollProgress />
    <CommandPalette />
    <slot />
    <BackToTop />
  </body>
</html>
