---
import LandingLayout from '../layouts/LandingLayout.astro';
import Nav from '../components/landing/Nav.astro';
import Hero from '../components/landing/Hero.astro';
import TrustBlock from '../components/landing/TrustBlock.astro';
import ProblemSection from '../components/landing/ProblemSection.astro';
import FeatureGrid from '../components/landing/FeatureGrid.astro';
import ConfigShowcase from '../components/landing/ConfigShowcase.astro';
import QuickStart from '../components/landing/QuickStart.astro';
import ComparisonTable from '../components/landing/ComparisonTable.astro';
import FinalCTA from '../components/landing/FinalCTA.astro';
import Footer from '../components/landing/Footer.astro';
---

<LandingLayout>
  <Nav />
  <main>
    <Hero />
    <TrustBlock />
    <div class="mx-auto max-w-5xl px-6"><hr style="border-color: var(--landing-divider);" /></div>
    <ProblemSection />
    <FeatureGrid />
    <div class="mx-auto max-w-5xl px-6"><hr style="border-color: var(--landing-divider);" /></div>
    <ConfigShowcase />
    <QuickStart />
    <div class="mx-auto max-w-5xl px-6"><hr style="border-color: var(--landing-divider);" /></div>
    <ComparisonTable />
    <FinalCTA />
  </main>
  <Footer />
</LandingLayout>
