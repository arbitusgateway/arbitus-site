---
const steps = [
  {
    num: '1',
    title: 'Install',
    command: 'cargo install arbitus',
    note: 'Single binary, no runtime dependencies.',
  },
  {
    num: '2',
    title: 'Configure',
    command: 'cp gateway.example.yml gateway.yml\n# edit gateway.yml with your policies',
    note: 'One YAML file controls everything.',
  },
  {
    num: '3',
    title: 'Run',
    command: 'arbitus gateway.yml',
    note: 'Point your agents at Arbitus instead of the MCP server.',
  },
];

const altInstalls = [
  { label: 'Docker', href: '/docs/deployment#docker' },
  { label: 'Helm', href: '/docs/deployment#kubernetes' },
  { label: 'Pre-built binaries', href: 'https://github.com/nfvelten/arbitus/releases' },
];
---

<section class="py-20 px-6">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl sm:text-4xl font-bold text-center mb-4 reveal">Up and running in 60 seconds</h2>
    <p class="text-center mb-14 max-w-2xl mx-auto reveal reveal-delay-1" style="color: var(--landing-text-secondary);">
      Three commands. No agents to install, no sidecars, no config servers.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {steps.map(({ num, title, command, note }, i) => (
        <div class={`rounded-xl p-8 transition-all hover:scale-[1.02] hover:shadow-xl reveal reveal-delay-${(i % 3) + 1}`} style="background-color: var(--landing-card-bg); border: 1px solid var(--landing-card-border);">
          <div class="flex items-center gap-3 mb-4">
            <span class="w-10 h-10 rounded-full text-sm font-bold flex items-center justify-center shrink-0" style="background-color: var(--landing-table-highlight); border: 1px solid var(--landing-accent-dot); color: var(--landing-accent-dot);">
              {num}
            </span>
            <h3 class="text-xl font-bold">{title}</h3>
          </div>
          <pre class="text-sm font-mono rounded-lg p-4 overflow-x-auto shadow-inner" style="background-color: var(--landing-code-bg); color: var(--landing-code-accent); border: 1px solid var(--landing-card-border);"><code set:text={command} /></pre>
          <p class="text-sm mt-4 leading-relaxed" style="color: var(--landing-text-secondary);">{note}</p>
        </div>
      ))}
    </div>

    <div class="mt-12 flex flex-wrap items-center justify-center gap-8 text-sm reveal reveal-delay-4" style="color: var(--landing-text-secondary);">
      <span class="font-medium">Also available via:</span>
      {altInstalls.map(({ label, href }) => (
        <a
          href={href}
          class="underline underline-offset-4 decoration-[var(--landing-accent-dot)]/30 hover:decoration-[var(--landing-accent-dot)] transition-all"
          style="color: var(--landing-text-secondary);"
          {...(href.startsWith('http') ? { target: '_blank', rel: 'noopener' } : {})}
        >
          {label}
        </a>
      ))}
    </div>
  </div>
</section>
