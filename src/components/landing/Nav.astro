---
import Logo from './Logo.astro';

const links = [
  { label: 'Docs', href: '/docs' },
  { label: 'GitHub', href: 'https://github.com/nfvelten/arbitus', external: true },
];
---

<header id="nav" class="fixed top-0 left-0 right-0 z-50 transition-colors duration-200">
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2.5 group" style="color: var(--landing-text);">
      <Logo class="transition-transform group-hover:scale-110" />
      <span class="text-lg font-bold tracking-tight">Arbitus</span>
    </a>

    <nav class="hidden sm:flex items-center gap-6">
      {links.map(({ label, href, external }) => (
        <a
          href={href}
          class="text-sm transition-colors nav-link"
          {...(external ? { target: '_blank', rel: 'noopener' } : {})}
        >
          {label}
        </a>
      ))}
      <button
        id="theme-toggle"
        class="p-2 rounded-lg transition-colors nav-link"
        aria-label="Toggle theme"
      >
        <svg id="theme-icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
        <svg id="theme-icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      </button>
      <a
        href="/docs/getting-started"
        class="text-sm font-medium px-4 py-1.5 rounded-lg transition-colors"
        style="background-color: var(--landing-btn-primary-bg); color: var(--landing-btn-primary-text);"
      >
        Get Started
      </a>
    </nav>

    <div class="sm:hidden flex items-center gap-2">
      <button
        id="theme-toggle-mobile"
        class="p-2 rounded-lg transition-colors nav-link"
        aria-label="Toggle theme"
      >
        <svg id="theme-icon-sun-m" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
        <svg id="theme-icon-moon-m" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      </button>
      <button
        id="mobile-menu-btn"
        class="transition-colors nav-link"
        aria-label="Toggle menu"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden sm:hidden backdrop-blur-md" style="border-top: 1px solid var(--landing-mobile-menu-border); background-color: var(--landing-mobile-menu-bg);">
    <div class="max-w-6xl mx-auto px-6 py-4 flex flex-col gap-3">
      {links.map(({ label, href, external }) => (
        <a
          href={href}
          class="text-sm transition-colors py-1 nav-link"
          {...(external ? { target: '_blank', rel: 'noopener' } : {})}
        >
          {label}
        </a>
      ))}
      <a
        href="/docs/getting-started"
        class="text-sm font-medium px-4 py-2 rounded-lg transition-colors text-center mt-1"
        style="background-color: var(--landing-btn-primary-bg); color: var(--landing-btn-primary-text);"
      >
        Get Started
      </a>
    </div>
  </div>
</header>

<style>
  .nav-link {
    color: var(--landing-text-secondary);
  }
  .nav-link:hover {
    color: var(--landing-text);
  }
</style>

<script>
  function updateThemeIcons() {
    const isDark = document.documentElement.dataset.theme === 'dark';
    ['theme-icon-sun', 'theme-icon-sun-m'].forEach(id => {
      const el = document.getElementById(id);
      if (el) el.classList.toggle('hidden', !isDark);
    });
    ['theme-icon-moon', 'theme-icon-moon-m'].forEach(id => {
      const el = document.getElementById(id);
      if (el) el.classList.toggle('hidden', isDark);
    });
  }

  function toggleTheme() {
    const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
    document.documentElement.dataset.theme = next;
    localStorage.setItem('starlight-theme', next);
    const meta = document.getElementById('color-scheme-meta');
    if (meta) meta.setAttribute('content', next);
    updateThemeIcons();
  }

  function initNav() {
    updateThemeIcons();
    
    const themeToggle = document.getElementById('theme-toggle');
    const themeToggleMobile = document.getElementById('theme-toggle-mobile');
    
    if (themeToggle) {
      themeToggle.addEventListener('click', toggleTheme);
    }
    
    if (themeToggleMobile) {
      themeToggleMobile.addEventListener('click', toggleTheme);
    }

    const nav = document.getElementById('nav');
    const menuBtn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');

    if (nav) {
      const update = () => {
        if (window.scrollY > 20) {
          nav.style.backgroundColor = getComputedStyle(document.documentElement).getPropertyValue('--landing-nav-bg');
          nav.style.backdropFilter = 'blur(12px)';
        } else {
          nav.style.backgroundColor = 'transparent';
          nav.style.backdropFilter = 'none';
        }
      };
      window.addEventListener('scroll', update, { passive: true });
      update();
    }

    if (menuBtn && menu) {
      menuBtn.addEventListener('click', () => menu.classList.toggle('hidden'));
    }
  }

  // Initialize on first load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initNav);
  } else {
    initNav();
  }

  // Re-initialize after Astro View Transitions
  document.addEventListener('astro:page-load', initNav);
</script>
