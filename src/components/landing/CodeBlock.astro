---
interface Props {
  code: string;
  language?: string;
  filename?: string;
}

const { code, language = 'text', filename } = Astro.props;

const lines = code.trim().split('\n');
const lineCount = lines.length;
---

<div class="rounded-xl overflow-hidden" style="background-color: var(--landing-code-bg); border: 1px solid var(--landing-card-border);">
  {filename && (
    <div class="flex items-center gap-2 px-4 py-2" style="border-bottom: 1px solid var(--landing-card-border);">
      <div class="flex gap-1.5">
        <span class="w-3 h-3 rounded-full bg-red-500/70"></span>
        <span class="w-3 h-3 rounded-full bg-yellow-500/70"></span>
        <span class="w-3 h-3 rounded-full bg-green-500/70"></span>
      </div>
      <span class="text-xs font-mono ml-2" style="color: var(--landing-code-text);">{filename}</span>
    </div>
  )}
  
  <div class="relative">
    <div class="flex">
      {lineCount > 1 && (
        <div class="flex-shrink-0 px-4 py-4 text-right select-none" style="color: var(--landing-text-muted); min-width: 3rem;">
          {lines.map((_, i) => (
            <div class="text-xs font-mono leading-relaxed" style="line-height: 1.5;">
              {i + 1}
            </div>
          ))}
        </div>
      )}
      
      <pre class="flex-1 p-4 overflow-x-auto text-sm font-mono leading-relaxed" style="color: var(--landing-code-text);"><code>{code}</code></pre>
    </div>
    
    <button 
      class="copy-code-btn absolute top-2 right-2 p-2 rounded-lg transition-all opacity-0 group-hover:opacity-100"
      data-code={code}
      aria-label="Copy code"
      style="background-color: var(--landing-card-bg-hover); color: var(--landing-text);"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
      </svg>
      <svg class="check-icon hidden w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
      </svg>
    </button>
    
    {language && language !== 'text' && (
      <span class="absolute bottom-2 right-2 text-xs px-2 py-1 rounded" style="background-color: var(--landing-badge-bg); color: var(--landing-badge-text); border: 1px solid var(--landing-badge-border);">
        {language}
      </span>
    )}
  </div>
</div>

<style>
  .copy-code-btn:hover {
    transform: scale(1.05);
  }
  
  .copy-code-btn:active {
    transform: scale(0.95);
  }
  
  div:hover .copy-code-btn {
    opacity: 1;
  }
</style>

<script>
  document.querySelectorAll('.copy-code-btn').forEach(button => {
    button.addEventListener('click', async () => {
      const code = button.getAttribute('data-code');
      if (!code) return;
      
      try {
        await navigator.clipboard.writeText(code);
        
        const copyIcon = button.querySelector('svg:not(.check-icon)');
        const checkIcon = button.querySelector('.check-icon');
        
        copyIcon.classList.add('hidden');
        checkIcon.classList.remove('hidden');
        
        setTimeout(() => {
          copyIcon.classList.remove('hidden');
          checkIcon.classList.add('hidden');
        }, 2000);
      } catch (err) {
        console.error('Failed to copy:', err);
      }
    });
  });
</script>