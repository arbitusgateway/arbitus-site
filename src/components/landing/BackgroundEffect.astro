---
---

<canvas id="bg-canvas"></canvas>

<style>
  #bg-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    pointer-events: none;
  }
</style>

<script>
  class NetworkBackground {
    constructor() {
      this.canvas = document.getElementById('bg-canvas');
      if (!this.canvas) return;
      
      this.ctx = this.canvas.getContext('2d');
      this.nodes = [];
      this.connections = [];
      this.mouse = { x: null, y: null };
      this.maxNodes = 80;
      this.connectionDistance = 150;
      
      this.resize();
      this.init();
      this.animate();
      
      window.addEventListener('resize', () => this.resize());
      window.addEventListener('mousemove', (e) => {
        this.mouse.x = e.clientX;
        this.mouse.y = e.clientY;
      });
    }
    
    resize() {
      this.canvas.width = window.innerWidth;
      this.canvas.height = window.innerHeight;
    }
    
    getColor(opacity = 0.5) {
      const isDark = document.documentElement.dataset.theme === 'dark';
      // Cyan for light mode, brighter cyan for dark mode
      return isDark ? `rgba(134, 239, 172, ${opacity})` : `rgba(20, 184, 166, ${opacity})`;
    }
    
    getGridColor(opacity = 0.08) {
      const isDark = document.documentElement.dataset.theme === 'dark';
      // Light grid lines for both modes
      return isDark ? `rgba(134, 239, 172, ${opacity})` : `rgba(180, 160, 120, ${opacity})`;
    }
    
    init() {
      const nodeCount = Math.min(this.maxNodes, Math.floor((this.canvas.width * this.canvas.height) / 20000));
      
      for (let i = 0; i < nodeCount; i++) {
        this.nodes.push({
          x: Math.random() * this.canvas.width,
          y: Math.random() * this.canvas.height,
          vx: (Math.random() - 0.5) * 0.3,
          vy: (Math.random() - 0.5) * 0.3,
          radius: Math.random() * 2 + 1,
        });
      }
    }
    
    drawGrid() {
      const gridSize = 60;
      const ctx = this.ctx;
      
      ctx.strokeStyle = this.getGridColor(0.06);
      ctx.lineWidth = 1;
      
      // Vertical lines
      for (let x = 0; x <= this.canvas.width; x += gridSize) {
        ctx.beginPath();
        ctx.moveTo(x, 0);
        ctx.lineTo(x, this.canvas.height);
        ctx.stroke();
      }
      
      // Horizontal lines
      for (let y = 0; y <= this.canvas.height; y += gridSize) {
        ctx.beginPath();
        ctx.moveTo(0, y);
        ctx.lineTo(this.canvas.width, y);
        ctx.stroke();
      }
    }
    
    drawGlow() {
      const centerX = this.canvas.width / 2;
      const centerY = this.canvas.height * 0.2;
      const gradient = this.ctx.createRadialGradient(centerX, centerY, 0, centerX, centerY, this.canvas.width * 0.6);
      
      gradient.addColorStop(0, this.getColor(0.08));
      gradient.addColorStop(0.5, this.getColor(0.04));
      gradient.addColorStop(1, 'transparent');
      
      this.ctx.fillStyle = gradient;
      this.ctx.fillRect(0, 0, this.canvas.width, this.canvas.height);
    }
    
    updateNodes() {
      this.nodes.forEach(node => {
        // Move
        node.x += node.vx;
        node.y += node.vy;
        
        // Bounce off edges
        if (node.x < 0 || node.x > this.canvas.width) node.vx *= -1;
        if (node.y < 0 || node.y > this.canvas.height) node.vy *= -1;
        
        // Keep in bounds
        node.x = Math.max(0, Math.min(this.canvas.width, node.x));
        node.y = Math.max(0, Math.min(this.canvas.height, node.y));
      });
    }
    
    drawNodes() {
      this.ctx.fillStyle = this.getColor(0.5);
      
      this.nodes.forEach(node => {
        this.ctx.beginPath();
        this.ctx.arc(node.x, node.y, node.radius, 0, Math.PI * 2);
        this.ctx.fill();
      });
    }
    
    drawConnections() {
      const ctx = this.ctx;
      
      for (let i = 0; i < this.nodes.length; i++) {
        for (let j = i + 1; j < this.nodes.length; j++) {
          const dx = this.nodes[i].x - this.nodes[j].x;
          const dy = this.nodes[i].y - this.nodes[j].y;
          const distance = Math.sqrt(dx * dx + dy * dy);
          
          if (distance < this.connectionDistance) {
            const opacity = (1 - distance / this.connectionDistance) * 0.3;
            ctx.strokeStyle = this.getColor(opacity);
            ctx.lineWidth = 1;
            ctx.beginPath();
            ctx.moveTo(this.nodes[i].x, this.nodes[i].y);
            ctx.lineTo(this.nodes[j].x, this.nodes[j].y);
            ctx.stroke();
          }
        }
      }
      
      // Connect to mouse with strongest lines
      if (this.mouse.x && this.mouse.y) {
        this.nodes.forEach(node => {
          const dx = node.x - this.mouse.x;
          const dy = node.y - this.mouse.y;
          const distance = Math.sqrt(dx * dx + dy * dy);
          
          if (distance < this.connectionDistance * 1.5) {
            const opacity = (1 - distance / (this.connectionDistance * 1.5)) * 0.6;
            ctx.strokeStyle = this.getColor(opacity);
            ctx.lineWidth = 2;
            ctx.beginPath();
            ctx.moveTo(node.x, node.y);
            ctx.lineTo(this.mouse.x, this.mouse.y);
            ctx.stroke();
          }
        });
      }
    }
    
    animate() {
      // Clear with background color
      const isDark = document.documentElement.dataset.theme === 'dark';
      this.ctx.fillStyle = isDark ? '#4f5b49' : '#faf1c6';
      this.ctx.fillRect(0, 0, this.canvas.width, this.canvas.height);
      
      // Draw layers
      this.drawGrid();
      this.drawGlow();
      this.updateNodes();
      this.drawConnections();
      this.drawNodes();
      
      requestAnimationFrame(() => this.animate());
    }
  }
  
  // Initialize
  function initBackground() {
    new NetworkBackground();
  }
  
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initBackground);
  } else {
    initBackground();
  }
  
  // Re-init on theme change
  const observer = new MutationObserver(() => {
    // Just need to re-get colors - the animate loop will pick up changes
  });
  
  observer.observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['data-theme']
  });
  
  // Re-init after Astro view transitions
  document.addEventListener('astro:page-load', () => {
    // Canvas continues animating, just need to recalc colors
  });
</script>
