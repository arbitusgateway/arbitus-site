---
---

<div id="bg-container" style="position: fixed; inset: 0; pointer-events: none; z-index: 0;">
  <div id="bg-base" style="position: absolute; inset: 0;"></div>
  <div id="bg-grid" style="position: absolute; inset: 0;"></div>
  <div id="bg-glow" style="position: absolute; inset: 0;"></div>
</div>

<script>
  function updateBackground() {
    const isDark = document.documentElement.dataset.theme === 'dark';
    const base = document.getElementById('bg-base');
    const grid = document.getElementById('bg-grid');
    const glow = document.getElementById('bg-glow');
    
    if (!base || !grid || !glow) {
      console.log('Background elements not found');
      return;
    }
    
    // Set base background color
    base.style.backgroundColor = isDark ? '#0a0a0a' : '#ffffff';
    
    // Set grid pattern with higher visibility
    const gridColor = isDark ? 'rgba(113, 113, 122, 0.3)' : 'rgba(156, 163, 175, 0.25)';
    grid.style.backgroundImage = `
      linear-gradient(to right, ${gridColor} 1px, transparent 1px),
      linear-gradient(to bottom, ${gridColor} 1px, transparent 1px)
    `;
    grid.style.backgroundSize = '50px 50px';
    grid.style.maskImage = 'radial-gradient(ellipse 100% 80% at 50% 10%, black 20%, transparent 70%)';
    grid.style.webkitMaskImage = 'radial-gradient(ellipse 100% 80% at 50% 10%, black 20%, transparent 70%)';
    
    // Set glow effect - much more visible
    const glowColor1 = isDark ? 'rgba(34, 211, 238, 0.25)' : 'rgba(6, 182, 212, 0.3)';
    const glowColor2 = isDark ? 'rgba(34, 211, 238, 0.15)' : 'rgba(6, 182, 212, 0.2)';
    glow.style.background = `radial-gradient(ellipse 150% 50% at 50% -10%, ${glowColor1} 0%, ${glowColor2} 30%, transparent 70%)`;
    glow.style.filter = 'blur(60px)';
    
    console.log('Background updated for theme:', isDark ? 'dark' : 'light');
  }
  
  // Initial update
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', updateBackground);
  } else {
    updateBackground();
  }
  
  // Update on theme change
  const observer = new MutationObserver((mutations) => {
    mutations.forEach((mutation) => {
      if (mutation.attributeName === 'data-theme') {
        updateBackground();
      }
    });
  });
  
  observer.observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['data-theme']
  });
  
  // Re-initialize after Astro View transitions
  document.addEventListener('astro:page-load', updateBackground);
</script>
