---
---

<div class="background-container fixed inset-0 -z-10 overflow-hidden pointer-events-none">
  <div class="grid-effect"></div>
  <div class="glow-effect"></div>
  <div class="synapses-effect"></div>
</div>

<style>
  .background-container {
    background-color: var(--landing-bg);
  }

  .grid-effect {
    position: absolute;
    inset: 0;
    background-image: 
      linear-gradient(to right, #e4e4e7 1px, transparent 1px),
      linear-gradient(to bottom, #e4e4e7 1px, transparent 1px);
    background-size: 40px 40px;
    mask-image: radial-gradient(circle at 50% 30%, black 40%, transparent 80%);
    -webkit-mask-image: radial-gradient(circle at 50% 30%, black 40%, transparent 80%);
    opacity: 0.4;
  }

  html[data-theme='dark'] .grid-effect {
    background-image: 
      linear-gradient(to right, #27272a 1px, transparent 1px),
      linear-gradient(to bottom, #27272a 1px, transparent 1px);
    opacity: 0.3;
  }

  .glow-effect {
    position: absolute;
    top: -10%;
    left: 50%;
    transform: translateX(-50%);
    width: 150%;
    height: 60%;
    background: radial-gradient(
      ellipse at center,
      rgba(6, 182, 212, 0.12) 0%,
      rgba(6, 182, 212, 0.05) 30%,
      transparent 70%
    );
    pointer-events: none;
  }

  html[data-theme='dark'] .glow-effect {
    background: radial-gradient(
      ellipse at center,
      rgba(34, 211, 238, 0.08) 0%,
      rgba(34, 211, 238, 0.03) 30%,
      transparent 70%
    );
  }

  .synapses-effect {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 300px;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      rgba(6, 182, 212, 0.03) 50%,
      transparent 100%
    );
    animation: scan 10s ease-in-out infinite;
    opacity: 0.6;
  }

  html[data-theme='dark'] .synapses-effect {
    background: linear-gradient(
      to bottom,
      transparent 0%,
      rgba(34, 211, 238, 0.02) 50%,
      transparent 100%
    );
  }

  @keyframes scan {
    0%, 100% {
      transform: translateY(-100%);
      opacity: 0;
    }
    50% {
      opacity: 0.6;
    }
    100% {
      transform: translateY(calc(100vh - 100%));
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .synapses-effect {
      animation: none;
      opacity: 0.3;
    }
  }
</style>
