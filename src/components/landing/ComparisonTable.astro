---
const features = [
  { name: 'Per-agent authentication', tooltip: 'JWT/OIDC, API keys, mTLS per agent identity' },
  { name: 'Encoding-aware filtering', tooltip: 'Catches Base64, URL-encoded, Unicode obfuscation' },
  { name: 'Human-in-the-loop', tooltip: 'Suspend dangerous calls for operator approval' },
  { name: 'Shadow mode', tooltip: 'Intercept without forwarding (dry-run)' },
  { name: 'OPA/Rego policies', tooltip: 'Industry-standard policy engine (Kubernetes, Terraform)' },
  { name: 'Supply-chain verification', tooltip: 'SHA-256 + cosign binary verification' },
  { name: 'HTTP + stdio transports', tooltip: 'Works with any MCP server type' },
  { name: 'Sub-millisecond overhead', tooltip: 'Measured in production workloads' },
  { name: 'Open source (MIT)', tooltip: 'Free to use, modify, and distribute' },
];

type Support = 'yes' | 'no' | 'partial';

const competitors: { name: string; link?: string; values: Support[]; note?: string }[] = [
  { 
    name: 'Arbitus', 
    link: 'https://github.com/arbitusgateway/arbitus',
    values: ['yes', 'yes', 'yes', 'yes', 'yes', 'yes', 'yes', 'yes', 'yes'] 
  },
  { 
    name: 'agentgateway', 
    link: 'https://github.com/A interests/agentgateway',
    values: ['yes', 'no', 'no', 'no', 'no', 'no', 'yes', 'yes', 'yes'],
    note: 'Linux Foundation project, connectivity-focused'
  },
  { 
    name: 'Direct MCP', 
    link: 'https://modelcontextprotocol.io',
    values: ['no', 'no', 'no', 'no', 'no', 'no', 'yes', 'yes', 'yes'],
    note: 'No security layer by default'
  },
  { 
    name: 'Commercial WAF', 
    values: ['yes', 'partial', 'partial', 'no', 'partial', 'partial', 'yes', 'partial', 'no'],
    note: 'Varies by vendor, typically no agent awareness'
  },
];

function icon(v: Support) {
  if (v === 'yes') return { symbol: '✓', color: 'var(--landing-check)', title: 'Full support' };
  if (v === 'partial') return { symbol: '~', color: 'var(--landing-partial)', title: 'Partial support' };
  return { symbol: '✗', color: 'var(--landing-cross)', title: 'Not supported' };
}
---

<section class="py-20 px-6">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-3xl sm:text-4xl font-bold text-center mb-4 reveal">How Arbitus compares</h2>
    <p class="text-center mb-12 max-w-2xl mx-auto reveal reveal-delay-1" style="color: var(--landing-text-secondary);">
      The only open-source gateway with the complete security stack for MCP.
    </p>

    <div class="overflow-x-auto rounded-xl reveal reveal-delay-2 shadow-xl" style="background-color: var(--landing-card-bg); border: 1px solid var(--landing-card-border);">
      <table class="w-full text-sm">
        <thead>
          <tr style="border-bottom: 1px solid var(--landing-table-header-border);">
            <th class="text-left py-4 pl-5 pr-4 font-medium" style="color: var(--landing-text-secondary);">Feature</th>
            {competitors.map(({ name, link }) => (
              <th
                class="text-center py-4 px-5 font-bold"
                style={name === 'Arbitus' ? `color: var(--landing-check); background-color: var(--landing-table-highlight);` : `color: var(--landing-text-secondary);`}
              >
                {link ? (
                  <a 
                    href={link} 
                    target="_blank" 
                    rel="noopener"
                    class="hover:underline transition-colors"
                    style={name === 'Arbitus' ? '' : 'color: var(--landing-text-secondary);'}
                  >
                    {name}
                    {name !== 'Arbitus' && (
                      <svg class="inline-block w-3 h-3 ml-1 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                      </svg>
                    )}
                  </a>
                ) : (
                  <span>{name}</span>
                )}
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {features.map(({ name: feature, tooltip }, i) => (
            <tr style={`border-bottom: 1px solid var(--landing-table-row-border);`} class="transition-colors hover:bg-[var(--landing-card-bg-hover)] group">
              <td class="py-3.5 pl-5 pr-4">
                <span style="color: var(--landing-text);" class="flex items-center gap-2">
                  {feature}
                  <span 
                    class="opacity-0 group-hover:opacity-100 transition-opacity cursor-help" 
                    title={tooltip}
                    style="color: var(--landing-text-muted);"
                  >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                  </span>
                </span>
              </td>
              {competitors.map(({ name, values }) => {
                const { symbol, color, title } = icon(values[i]);
                return (
                  <td
                    class="text-center py-3.5 px-5 text-lg font-bold"
                    style={`color: ${color};${name === 'Arbitus' ? ' background-color: var(--landing-table-highlight);' : ''}`}
                    title={title}
                  >{symbol}</td>
                );
              })}
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div class="mt-6 grid grid-cols-1 sm:grid-cols-3 gap-4 reveal reveal-delay-3">
      {competitors.slice(1).map(({ name, link, note }) => (
        <div class="rounded-lg p-4 text-sm" style="background-color: var(--landing-card-bg); border: 1px solid var(--landing-card-border);">
          <div class="font-semibold mb-1" style="color: var(--landing-text);">{name}</div>
          {note && <div style="color: var(--landing-text-muted);">{note}</div>}
          {link && (
            <a 
              href={link} 
              target="_blank" 
              rel="noopener"
              class="inline-flex items-center gap-1 mt-2 text-xs"
              style="color: var(--landing-accent-dot);"
            >
              View project
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          )}
        </div>
      ))}
    </div>
  </div>
</section>