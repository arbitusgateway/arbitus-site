---
import Logo from './Logo.astro';

const columns = [
  {
    title: 'Product',
    links: [
      { label: 'Documentation', href: '/docs' },
      { label: 'Getting Started', href: '/docs/getting-started' },
      { label: 'Configuration', href: '/docs/configuration' },
      { label: 'GitHub', href: 'https://github.com/arbitusgateway/arbitus', external: true },
    ],
  },
  {
    title: 'Resources',
    links: [
      { label: 'Changelog', href: 'https://github.com/arbitusgateway/arbitus/blob/main/CHANGELOG.md', external: true },
      { label: 'Architecture', href: '/docs/architecture' },
      { label: 'Security', href: '/docs/security' },
      { label: 'Deployment', href: '/docs/deployment' },
    ],
  },
  {
    title: 'Project',
    links: [
      { label: 'MIT License', href: 'https://github.com/arbitusgateway/arbitus/blob/main/LICENSE', external: true },
      { label: 'Contributing', href: 'https://github.com/arbitusgateway/arbitus/blob/main/CONTRIBUTING.md', external: true },
      { label: 'crates.io', href: 'https://crates.io/crates/arbitus', external: true },
      { label: 'Built with Astro', href: 'https://astro.build', external: true },
    ],
  },
];

const socialLinks = [
  { name: 'GitHub', href: 'https://github.com/arbitusgateway/arbitus', icon: 'github' },
  { name: 'Twitter', href: 'https://twitter.com/arbitus', icon: 'twitter' },
];
---

<footer class="py-16 px-6 reveal" style="border-top: 1px solid var(--landing-footer-border); background-color: var(--landing-footer-bg);">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-10 mb-8">
      <div>
        <a href="/" class="flex items-center gap-2.5 group" style="color: var(--landing-text);">
          <Logo class="transition-transform group-hover:scale-110" width="24" height="24" />
          <span class="text-base font-bold tracking-tight">Arbitus</span>
        </a>
        <p class="text-sm mt-3 leading-relaxed" style="color: var(--landing-text-muted);">
          The security proxy for<br />AI agents and MCP servers.
        </p>
      </div>

      {columns.map(({ title, links }) => (
        <div>
          <h4 class="text-sm font-semibold mb-4">{title}</h4>
          <ul class="space-y-2.5">
            {links.map(({ label, href, external }) => (
              <li>
                <a
                  href={href}
                  class="text-sm transition-all footer-link hover:translate-x-1 inline-block"
                  {...(external ? { target: '_blank', rel: 'noopener' } : {})}
                >
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="pt-8 flex flex-col md:flex-row justify-between items-center gap-4" style="border-top: 1px solid var(--landing-divider);">
      <div class="flex items-center gap-4">
        {socialLinks.map(({ name, href, icon }) => (
          <a
            href={href}
            target="_blank"
            rel="noopener"
            class="p-2 rounded-lg transition-all hover:scale-110 social-link"
            style="color: var(--landing-text-secondary);"
            aria-label={name}
          >
            {icon === 'github' && (
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
            )}
            {icon === 'twitter' && (
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            )}
          </a>
        ))}
      </div>
      
      <p class="text-xs" style="color: var(--landing-copy-text);">
        &copy; {new Date().getFullYear()} Arbitus. MIT Licensed.
      </p>
    </div>
  </div>
</footer>

<style>
  .footer-link {
    color: var(--landing-text-secondary);
  }
  .footer-link:hover {
    color: var(--landing-text);
  }
  
  .social-link:hover {
    color: var(--landing-accent-dot);
    background-color: var(--landing-card-bg-hover);
  }
</style>
